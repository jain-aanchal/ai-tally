# Copy to .env and fill in for `make chatbot-demo`.
# Both API keys are required when --dry-run is NOT passed; the driver hits the
# real OpenAI / Anthropic APIs via the chatbot's /api/demo-chat route.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Where the chatbot POSTs spans + CDP events. Match `make up` defaults.
TALLY_GATEWAY_URL=http://localhost:8080/v1/batches
TALLY_TENANT=local-dev

# Optional — override the models the driver asks for.
TALLY_OPENAI_MODEL=gpt-4o-mini
TALLY_ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Where run.sh boots the chatbot.
TALLY_CHATBOT_URL=http://localhost:3001
